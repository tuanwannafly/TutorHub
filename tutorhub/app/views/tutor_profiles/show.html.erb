<% content_for :title, @tutor_profile.display_name %>

<section class="tutor-show">
  <header class="tutor-header card">
    <div class="tutor-header-main">
      <h1><%= @tutor_profile.display_name %></h1>
      <p class="tutor-subject"><%= @tutor_profile.subject.presence || "General tutoring" %></p>
      <% if @tutor_profile.headline.present? %>
        <p class="tutor-headline"><%= @tutor_profile.headline %></p>
      <% end %>
    </div>

    <div class="tutor-header-meta">
      <div class="meta-item">
        <span class="meta-label">Hourly rate</span>
        <span class="meta-value"><strong><%= number_to_currency(@tutor_profile.hourly_rate) %></strong></span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Member since</span>
        <span class="meta-value"><%= @tutor_profile.created_at.to_date.to_formatted_s(:long) %></span>
      </div>
    </div>
  </header>

  <% if @tutor_profile.bio.present? %>
    <section class="tutor-bio card">
      <h2>About</h2>
      <p><%= simple_format(@tutor_profile.bio) %></p>
    </section>
  <% end %>

  <section class="tutor-availability">
    <h2>Availability</h2>

    <% if @availabilities.empty? %>
      <p class="empty-state">This tutor hasn't published any availability windows yet.</p>
    <% else %>
      <% Availability::DAYS_OF_WEEK.each do |n, label| %>
        <% windows = @grouped[n] || [] %>
        <% next if windows.empty? %>

        <div class="card day-group">
          <h3><%= label %></h3>
          <table class="availability-table">
            <thead>
              <tr>
                <th>Start</th>
                <th>End</th>
                <th>Length</th>
                <% if logged_in? && current_user.student? %>
                  <th class="actions-col">Book</th>
                <% end %>
              </tr>
            </thead>
            <tbody>
              <% windows.each do |window| %>
                <tr>
                  <td><%= window.start_time.strftime("%H:%M") %></td>
                  <td><%= window.end_time.strftime("%H:%M") %></td>
                  <td><%= window.length_minutes %> min</td>
                  <% if logged_in? && current_user.student? %>
                    <td class="actions-col">
                      <% next_date = Date.current.next_occurring(Date::ABBR_DAYNAMES.index(window.day_name[0,3].capitalize).to_i) %>
                      <%= form_with url: bookings_path, method: :post, local: true, class: "inline-book-form" do %>
                        <%= hidden_field_tag :tutor_id, @tutor_profile.user_id %>
                        <%= hidden_field_tag :booking_date, next_date %>
                        <%= hidden_field_tag :start_time, window.start_time.strftime("%H:%M:%S") %>
                        <%= hidden_field_tag :end_time,   window.end_time.strftime("%H:%M:%S") %>
                        <%= submit_tag "Book this slot", class: "btn btn-primary btn-small" %>
                      <% end %>
                    </td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    <% end %>
  </section>
</section>