<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? "#{content_for(:title)} — TutorHub" : "TutorHub" %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="stylesheet" href="<%= asset_path 'application.css' %>">
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="brand">TutorHub</a>
        <nav>
          <%= link_to "Browse tutors", tutors_path %>
          <% if current_user %>
            <%= link_to "Dashboard", dashboard_path %>
            <%= link_to "Log out", logout_path, data: { turbo_method: :delete } %>
          <% else %>
            <%= link_to "Log in", login_path %>
            <%= link_to "Sign up", signup_path, class: "btn btn-primary" %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="container">
      <% flash.each do |type, msg| %>
        <div class="flash flash--<%= type %>"><%= msg %></div>
      <% end %>

      <%= yield %>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>TutorHub &mdash; built with Rails 7. See <a href="https://github.com/&lt;you&gt;/tutorhub">GitHub</a>.</p>
      </div>
    </footer>
  </body>
</html>